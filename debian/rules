#!/usr/bin/make -f

export DH_VERBOSE = 1
export DOTNET_CLI_TELEMETRY_OPTOUT = 1
export DOTNET_NOLOGO = 1

%:
	dh $@

override_dh_auto_build:
	# Build the .NET API
	cd minicluster-api && dotnet publish ControlCenter.Api/Innovatek.ControlCenter.Api.csproj \
		-c Release \
		-o ../build/api \
		--self-contained false \
		-r linux-x64
	# Build the React UI
	cd minicluster-ui && npm ci && npm run build

override_dh_auto_install:
	# Install API
	install -d $(CURDIR)/debian/minicluster/opt/minicluster/api
	cp -r build/api/* $(CURDIR)/debian/minicluster/opt/minicluster/api/
	# Install UI
	install -d $(CURDIR)/debian/minicluster/opt/minicluster/ui
	cp -r minicluster-ui/build/client/* $(CURDIR)/debian/minicluster/opt/minicluster/ui/
	# Install systemd service
	install -d $(CURDIR)/debian/minicluster/lib/systemd/system
	install -m 644 debian/minicluster.service $(CURDIR)/debian/minicluster/lib/systemd/system/
	# Install configuration
	install -d $(CURDIR)/debian/minicluster/etc/minicluster
	install -m 644 minicluster-api/ControlCenter.Api/appsettings.json $(CURDIR)/debian/minicluster/etc/minicluster/
	# Install CLI wrapper
	install -d $(CURDIR)/debian/minicluster/usr/bin
	install -m 755 debian/minicluster-ctl $(CURDIR)/debian/minicluster/usr/bin/

override_dh_auto_clean:
	rm -rf build/
	rm -rf minicluster-ui/build/
	rm -rf minicluster-ui/node_modules/
	cd minicluster-api && dotnet clean || true

override_dh_auto_test:
	# Skip tests during package build
	true
