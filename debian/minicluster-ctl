#!/bin/bash
# MiniCluster Control CLI

MINICLUSTER_API="http://localhost:5147"

usage() {
    echo "MiniCluster Control CLI"
    echo ""
    echo "Usage: minicluster-ctl <command> [options]"
    echo ""
    echo "Commands:"
    echo "  status              Show service status"
    echo "  start               Start the MiniCluster service"
    echo "  stop                Stop the MiniCluster service"
    echo "  restart             Restart the MiniCluster service"
    echo "  logs [lines]        Show service logs (default: 50 lines)"
    echo "  health              Check API health"
    echo "  apps                List all applications"
    echo "  services            List all services"
    echo "  version             Show version information"
    echo ""
}

case "$1" in
    status)
        systemctl status minicluster.service
        ;;
    start)
        sudo systemctl start minicluster.service
        echo "MiniCluster started"
        ;;
    stop)
        sudo systemctl stop minicluster.service
        echo "MiniCluster stopped"
        ;;
    restart)
        sudo systemctl restart minicluster.service
        echo "MiniCluster restarted"
        ;;
    logs)
        LINES=${2:-50}
        journalctl -u minicluster.service -n "$LINES" --no-pager
        ;;
    health)
        if curl -s -o /dev/null -w "%{http_code}" "$MINICLUSTER_API/health" | grep -q "200"; then
            echo "MiniCluster API is healthy"
        else
            echo "MiniCluster API is not responding"
            exit 1
        fi
        ;;
    apps)
        curl -s "$MINICLUSTER_API/api/Apps" | python3 -m json.tool 2>/dev/null || echo "Failed to fetch apps"
        ;;
    services)
        curl -s "$MINICLUSTER_API/api/Services" | python3 -m json.tool 2>/dev/null || echo "Failed to fetch services"
        ;;
    version)
        echo "MiniCluster Control CLI v1.0.0"
        curl -s "$MINICLUSTER_API/api/version" 2>/dev/null || echo "API version unavailable"
        ;;
    help|--help|-h)
        usage
        ;;
    *)
        usage
        exit 1
        ;;
esac
