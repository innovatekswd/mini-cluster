{
  "include": [
    "**/*",
    "**/.server/**/*",
    "**/.client/**/*",
    ".react-router/types/**/*"
  ],
  "compilerOptions": {
    "lib": ["DOM", "DOM.Iterable", "ES2022"],
    "types": ["node", "vite/client", "vitest/globals"],
    "target": "ES2022",
    "module": "ES2022",
    "moduleResolution": "bundler",
    "jsx": "react-jsx",
    "rootDirs": [".", "./.react-router/types"],
    "baseUrl": ".",
    "paths": {
      "~/*": ["./app/*"],
      "@hivemind/grid": ["/home/younan/src/innovatek/HiveMind/packages/react/grid/dist/index.d.ts"],
      "@hivemind/shared": ["/home/younan/src/innovatek/HiveMind/packages/react/shared/dist/index.d.ts"]
    },
    "forceConsistentCasingInFileNames": true,
    "ignoreDeprecations": "5.0",
    "esModuleInterop": true,
    "verbatimModuleSyntax": true,
    "noEmit": true,
    "resolveJsonModule": true,
    "skipLibCheck": true,
    "strict": true
  }
}
