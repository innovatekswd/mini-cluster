{
  "name": "minicluster-e2e",
  "version": "1.0.0",
  "private": true,
  "description": "End-to-end tests for MiniCluster",
  "scripts": {
    "test": "playwright test",
    "test:go": "BACKEND=go BASE_URL=http://127.0.0.1:5000 playwright test",
    "test:dotnet": "BACKEND=dotnet playwright test",
    "test:api": "playwright test tests/api/",
    "test:api:go": "BACKEND=go BASE_URL=http://127.0.0.1:5000 playwright test tests/api/",
    "test:features": "playwright test tests/features/",
    "test:features:go": "BACKEND=go BASE_URL=http://127.0.0.1:5000 playwright test tests/features/",
    "test:auth": "playwright test tests/features/auth/",
    "test:dashboard": "playwright test tests/features/dashboard/",
    "test:apps": "playwright test tests/features/apps/",
    "test:services": "playwright test tests/features/services/",
    "test:environments": "playwright test tests/features/environments/",
    "test:settings": "playwright test tests/features/settings/",
    "test:regression": "playwright test tests/features/dashboard/regression.spec.ts",
    "test:regression:go": "BACKEND=go BASE_URL=http://127.0.0.1:5000 playwright test tests/features/dashboard/regression.spec.ts",
    "test:ui": "playwright test --ui",
    "test:headed": "playwright test --headed",
    "test:debug": "playwright test --debug",
    "report": "playwright show-report",
    "codegen": "playwright codegen http://localhost:5173"
  },
  "devDependencies": {
    "@playwright/test": "^1.50.0",
    "@types/node": "^25.2.2",
    "typescript": "^5.9.3"
  }
}
