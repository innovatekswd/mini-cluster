# ===========================================
# MiniCluster Monorepo .gitignore
# ===========================================

# OS files
.DS_Store
Thumbs.db

# IDE
.vs/
.vscode/
*.swp
*.swo
*~

# ===========================================
# .NET / API
# ===========================================

# User-specific files
*.rsuser
*.suo
*.user
*.userosscache
*.sln.docstates
*.zip
*.userprefs

# Mono auto generated files
mono_crash.*

# Build results
[Dd]ebug/
[Dd]ebugPublic/
[Rr]elease/
[Rr]eleases/
x64/
x86/
[Ww][Ii][Nn]32/
[Aa][Rr][Mm]/
[Aa][Rr][Mm]64/
bld/
[Bb]in/
[Oo]bj/
[Oo]ut/
[Ll]og/
[Ll]ogs/

# Visual Studio 2017 auto generated files
Generated\ Files/

# MSTest test Results
[Tt]est[Rr]esult*/
[Bb]uild[Ll]og.*

# NUnit
*.VisualState.xml
TestResult.xml
nunit-*.xml

# Build Results of an ATL Project
[Dd]ebugPS/
[Rr]eleasePS/
dlldata.c

# Benchmark Results
BenchmarkDotNet.Artifacts/

# .NET Core
project.lock.json
project.fragment.lock.json
artifacts/

# StyleCop
StyleCopReport.xml

# Files built by Visual Studio
*_i.c
*_p.c
*_h.h
*.ilk
*.meta
*.obj
*.iobj
*.pch
*.pdb
*.ipdb
*.pgc
*.pgd
*.rsp
*.sbr
*.tlb
*.tli
*.tlh
*.tmp
*.tmp_proj
*_wpftmp.csproj
*.log
*.vspscc
*.vssscc
.builds
*.pidb
*.svclog
*.scc

# Visual C++ cache files
ipch/
*.aps
*.ncb
*.opendb
*.opensdf
*.sdf
*.cachefile
*.VC.db
*.VC.VC.opendb

# Visual Studio profiler
*.psess
*.vsp
*.vspx
*.sap

# ReSharper
_ReSharper*/
*.[Rr]e[Ss]harper
*.DotSettings.user

# Code Coverage
*.dotCover
.axoCover/*
!.axoCover/settings.json
coverage*.json
coverage*.xml
coverage*.info
*.coverage
*.coveragexml

# NCrunch
_NCrunch_*
.*crunch*.local.xml
nCrunchTemp_*

# NuGet Packages
*.nupkg
*.snupkg
**/[Pp]ackages/*
!**/[Pp]ackages/build/
*.nuget.props
*.nuget.targets

# Visual Studio cache files
*.[Cc]ache
!?*.[Cc]ache/

# Others
ClientBin/
~$*
*.dbmdl
*.dbproj.schemaview
*.jfm
*.pfx
*.publishsettings

# Publish
publish/
*.[Pp]ublish.xml
*.azurePubxml
*.pubxml
*.publishproj

# SQL Server files
*.mdf
*.ldf
*.ndf

# SQLite Database files
*.db
*.db-shm
*.db-wal

# MSBuild Binary and Structured Log
*.binlog

# Build outputs
build/

# ===========================================
# Node.js / UI
# ===========================================

node_modules/
.react-router/
.tools/
ui/public/installHook.js.map

# Runtime config generated by local runs
api-go/config.yaml
config.yaml

# ===========================================
# Go / CLI
# ===========================================

# Go binaries
*.exe
*.exe~
*.dll
*.so
*.dylib

# Go test binary
*.test

# Go coverage
*.out

# Go workspace
go.work
go.work.sum

# ===========================================
# Python (if any scripts)
# ===========================================

__pycache__/
*.pyc
*.pyo
.env
venv/
.tools/
