#!/bin/bash
set -e

case "$1" in
    remove|upgrade|deconfigure)
        if systemctl is-active --quiet minicluster.service 2>/dev/null; then
            systemctl stop minicluster.service
        fi
        if systemctl is-enabled --quiet minicluster.service 2>/dev/null; then
            systemctl disable minicluster.service
        fi
        ;;
esac

#DEBHELPER#

exit 0
