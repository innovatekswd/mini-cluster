#!/usr/bin/make -f

export DH_VERBOSE = 1
export DOTNET_CLI_TELEMETRY_OPTOUT = 1
export DOTNET_NOLOGO = 1

%:
	dh $@

override_dh_auto_build:
	# Build .NET API
	mkdir -p build
	dotnet publish api/Innovatek.Parallel.MiniCluster.Api/Innovatek.Parallel.MiniCluster.Api.csproj \
		-c Release \
		-o build/publish \
		--self-contained false
	# Build React UI
	if [ -d "ui" ]; then \
		cd ui && npm ci && npm run build; \
		cp -r ui/build/client build/wwwroot; \
	fi

override_dh_auto_install:
	# Install API files
	install -d debian/minicluster/opt/minicluster
	cp -r build/publish/* debian/minicluster/opt/minicluster/
	# Install wwwroot if built
	if [ -d "build/wwwroot" ]; then \
		cp -r build/wwwroot debian/minicluster/opt/minicluster/; \
	fi
	# Install systemd service
	install -d debian/minicluster/lib/systemd/system
	install -m 644 debian/minicluster.service debian/minicluster/lib/systemd/system/
	# Install configuration directory
	install -d debian/minicluster/etc/minicluster
	install -m 644 api/Innovatek.Parallel.MiniCluster.Api/appsettings.json debian/minicluster/etc/minicluster/
	# Create symlink for config
	ln -sf /etc/minicluster/appsettings.json debian/minicluster/opt/minicluster/appsettings.json
	# Create data directory
	install -d debian/minicluster/var/lib/minicluster
	# Create log directory
	install -d debian/minicluster/var/log/minicluster

override_dh_auto_clean:
	rm -rf build
	rm -rf api/Innovatek.Parallel.MiniCluster.Api/bin api/Innovatek.Parallel.MiniCluster.Api/obj
	rm -rf api/Innovatek.Parallel.MiniCluster.Core/bin api/Innovatek.Parallel.MiniCluster.Core/obj
	rm -rf api/Innovatek.Parallel.Identity/bin api/Innovatek.Parallel.Identity/obj
	rm -rf api/Innovatek.Parallel.TemplateEngine/bin api/Innovatek.Parallel.TemplateEngine/obj

override_dh_strip:
	# Skip stripping for .NET assemblies

override_dh_shlibdeps:
	# Skip shared library dependencies for .NET
